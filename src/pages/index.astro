---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base>
  <section class="intro">
    <p>Hi, I'm Carl — this is mostly my Things I Learned (TIL) blog, but also provides a nice home for my <a href="/cv">CV</a>.</p>
    <nav class="intro-links">
      <a href="https://github.com/cmoberg" rel="noopener noreferrer">GitHub</a>
      <a href="https://twitter.com/cmoberg" rel="noopener noreferrer">Twitter</a>
      <a href="https://www.linkedin.com/in/carlmoberg/" rel="noopener noreferrer">LinkedIn</a>
      <a href="https://mastodon.social/@cmoberg" rel="me noopener noreferrer">Mastodon</a>
      <a href="mailto:callemoberg@gmail.com">Email</a>
      <a href="/feed.xml">RSS</a>
    </nav>
  </section>

  <ul class="post-list">
    {posts.map((post) => (
      <li class="post-item">
        <div class="post-meta">
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {post.data.tags && post.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
        <h2 class="post-title">
          <a href={`/blog/${post.id}`}>{post.data.title}</a>
        </h2>
        {post.data.summary && <p class="post-summary">{post.data.summary}</p>}
      </li>
    ))}
  </ul>
  {posts.length === 0 && <p>No posts yet.</p>}
</Base>
